# Copy to `.env` for local dev (Next.js + Prisma CLI both load it). `.env.local` also works for Next, but Prisma commands need `.env` unless you export DATABASE_URL.

# --- Neon PostgreSQL ---
# Create a project at https://neon.tech — use the pooled connection string for serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Clerk (https://dashboard.clerk.com) ---
# After creating an application, copy API keys from "API Keys".
# Allowed redirect URLs / domains: add `http://localhost:3000` for dev and your Vercel domain for prod.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Optional explicit URLs (defaults work if paths match):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- App URL (used by Stripe Checkout redirects) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Stripe (https://dashboard.stripe.com) ---
# Billing → Products: create "AI Trend Forge Pro" and "Founder" recurring prices; paste Price IDs here.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_FOUNDER="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- Billing admin exemption (optional) ---
# Comma-separated emails: Stripe webhooks never change `plan` for these users (same as DB `billing_exempt_from_stripe`).
# BILLING_EXEMPT_EMAILS="ops@example.com,founder@example.com"

# --- Phase 2 worker (optional placeholder) ---
# DEEPSEEK_API_KEY="..."

# ========= Deploy checklist =========
# 1) Neon: create DB → copy DATABASE_URL → run `npx prisma db push` (or `prisma migrate dev`) → `npm run db:seed`.
# 2) Vercel: import repo → Environment Variables: paste all keys above (use prod Clerk + Stripe keys for production).
# 3) Clerk: add production domain; set redirect URLs to `https://<your-domain>/sign-in` and `/sign-up`.
# 4) Stripe: endpoint `https://<your-domain>/api/webhooks/stripe` → events:
#    checkout.session.completed, customer.subscription.created/updated/deleted.
# 5) Local webhook testing: `stripe listen --forward-to localhost:3000/api/webhooks/stripe` → copy signing secret to STRIPE_WEBHOOK_SECRET.
