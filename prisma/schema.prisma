generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  clerkUserId      String   @unique @map("clerk_user_id")
  email            String?
  name             String?
  plan             String   @default("free")
  stripeCustomerId String?  @map("stripe_customer_id")
  createdAt        DateTime @default(now()) @map("created_at")

  favorites     Favorite[]
  subscriptions Subscription[]
  unlocks       OpportunityUnlock[]

  @@map("users")
}

model Opportunity {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  summary         String
  painPoint       String   @map("pain_point")
  targetUser      String   @map("target_user")
  category        String
  score           Int
  buildDifficulty String   @map("build_difficulty")
  pricingHint     String   @map("pricing_hint")
  launchChannels  String[] @map("launch_channels")
  mvpFeatures     String[] @map("mvp_features")
  sourcePlatform  String   @map("source_platform")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")

  whyNow          String? @map("why_now")
  icp             String?
  redditLaunch    String? @map("reddit_launch")
  saasPotential   String? @map("saas_potential")
  goToMarket      String? @map("go_to_market")
  landingHeadline String? @map("landing_headline")

  favorites Favorite[]
  unlocks   OpportunityUnlock[]

  @@map("opportunities")
}

model SourcePost {
  id            String   @id @default(uuid())
  platform      String
  title         String
  body          String
  url           String
  author        String?
  score         Int      @default(0)
  commentsCount Int      @default(0) @map("comments_count")
  createdAt     DateTime @default(now()) @map("created_at")
  rawJson       Json?    @map("raw_json")

  signals Signal[]

  @@map("source_posts")
}

model Signal {
  id             String     @id @default(uuid())
  sourcePostId   String     @map("source_post_id")
  sourcePost     SourcePost @relation(fields: [sourcePostId], references: [id], onDelete: Cascade)
  painScore      Int        @map("pain_score")
  buyIntent      Int        @map("buy_intent")
  urgency        Int
  aiBuildability Int        @map("ai_buildability")
  competition    Int
  finalScore     Int        @map("final_score")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@map("signals")
}

model Favorite {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String      @map("opportunity_id")
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([userId, opportunityId])
  @@map("favorites")
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 String
  status               String
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("subscriptions")
}

model OpportunityUnlock {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String      @map("opportunity_id")
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([userId, opportunityId])
  @@map("opportunity_unlocks")
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist")
}
